-- Update Layout
local function UpdateLayout(container)
    local input = string.lower(SearchBox.Text)
    local xPos = {0.03, 0.52}
    local yPos = 10
    local col = 1
    local visibleButtons = {}
    for _, obj in pairs(container:GetChildren()) do
        if obj:IsA("TextButton") then
            if input == "" or string.find(string.lower(obj.Name), input) then obj.Visible = true; table.insert(visibleButtons, obj) else obj.Visible = false end
        end
    end
    for i, btn in pairs(visibleButtons) do
        btn.Position = UDim2.new(xPos[col], 0, 0, yPos)
        if col == 2 then yPos = yPos + 45; col = 1 else col = 2 end
    end
end

