local AllMusicItems = {}
local function CreateMusicItem(name, audioId, yPos, index)
    local frame = Instance.new("Frame", MusicContainer); frame.Size = UDim2.new(0.95, 0, 0, 70); frame.Position = UDim2.new(0.025, 0, 0, yPos); frame.BackgroundColor3 = Color3.fromRGB(35, 35, 35); Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 4)
    local lbl = Instance.new("TextLabel", frame); lbl.Size = UDim2.new(1, -60, 0, 20); lbl.Position = UDim2.new(0, 10, 0, 5); lbl.Text = name; lbl.TextColor3 = Color3.new(1,1,1); lbl.BackgroundTransparency = 1; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 16
    local pBtn = Instance.new("TextButton", frame); pBtn.Size = UDim2.new(0, 40, 0, 40); pBtn.Position = UDim2.new(1, -45, 0, 15); pBtn.Text = "▶"; pBtn.TextColor3 = Color3.new(1, 1, 1); pBtn.BackgroundTransparency = 1; pBtn.Font = Enum.Font.GothamBold; pBtn.TextSize = 30
    local lBtn = Instance.new("TextButton", frame); lBtn.Size = UDim2.new(0, 30, 0, 30); lBtn.Position = UDim2.new(1, -80, 0, 20); lBtn.Text = "🔁"; lBtn.TextColor3 = Color3.new(0.5, 0.5, 0.5); lBtn.BackgroundTransparency = 1; lBtn.TextSize = 20
    
    local timeLbl = Instance.new("TextLabel", frame); timeLbl.Size = UDim2.new(0, 100, 0, 20); timeLbl.Position = UDim2.new(0, 10, 0, 25); timeLbl.TextColor3 = Color3.new(0.8, 0.8, 0.8); timeLbl.BackgroundTransparency = 1; timeLbl.Font = Enum.Font.Code; timeLbl.TextSize = 10; timeLbl.TextXAlignment = Enum.TextXAlignment.Left
    
    local barCont = Instance.new("TextButton", frame); barCont.Size = UDim2.new(0.6, 0, 0, 8); barCont.Position = UDim2.new(0.05, 0, 0, 50); barCont.BackgroundColor3 = Color3.fromRGB(20, 20, 20); barCont.Text = ""; Instance.new("UICorner", barCont).CornerRadius = UDim.new(0, 4)
    local bar = Instance.new("Frame", barCont); bar.Size = UDim2.new(0,0,1,0); bar.BackgroundColor3 = Color3.fromRGB(138, 43, 226); Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 4)
    
    local snd = Instance.new("Sound", workspace); snd.SoundId = "rbxassetid://"..audioId; snd.Volume = 2
    local loopMode = 0
    local isDragging = false

    local function updateTime(input) local relativeX = (input.Position.X - barCont.AbsolutePosition.X) / barCont.AbsoluteSize.X; snd.TimePosition = math.clamp(relativeX * snd.TimeLength, 0, snd.TimeLength) end
    barCont.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then isDragging = true; updateTime(input) end end)
    UIS.InputChanged:Connect(function(input) if isDragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then updateTime(input) end end)
    UIS.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then isDragging = false end end)

    lBtn.MouseButton1Click:Connect(function()
        loopMode = (loopMode + 1) % 3
        if loopMode == 0 then lBtn.Text = "🔁"; lBtn.TextColor3 = Color3.new(0.5, 0.5, 0.5)
        elseif loopMode == 1 then lBtn.Text = "🔁"; lBtn.TextColor3 = Color3.fromRGB(0, 120, 215)
        else lBtn.Text = "🔂"; lBtn.TextColor3 = Color3.fromRGB(0, 120, 215) end
    end)

    local function triggerPlay() for _, item in pairs(AllMusicItems) do item.Sound:Stop(); item.Button.Text = "▶" end; snd:Play(); pBtn.Text = "⏸" end
    pBtn.MouseButton1Click:Connect(function() if snd.IsPlaying then snd:Stop(); pBtn.Text = "▶" else triggerPlay() end end)    
    snd.Ended:Connect(function() 
        if loopMode == 1 then snd.TimePosition = 0; snd:Play(); loopMode = 0; lBtn.Text = "🔁"; lBtn.TextColor3 = Color3.new(0.5, 0.5, 0.5)
        elseif loopMode == 2 then snd.TimePosition = 0; snd:Play()
        else pBtn.Text = "▶"; local n = (index % #AllMusicItems) + 1; AllMusicItems[n].Trigger() end 
    end)
    
    AllMusicItems[index] = {Sound = snd, Button = pBtn, Trigger = triggerPlay}
    
    task.spawn(function() while task.wait(0.1) do if snd.TimeLength > 0 and not isDragging then timeLbl.Text = string.format("%02d:%02d / %02d:%02d", snd.TimePosition/60, snd.TimePosition%60, snd.TimeLength/60, snd.TimeLength%60); bar.Size = UDim2.new(math.clamp(snd.TimePosition/snd.TimeLength, 0, 1), 0, 1, 0) end end end)
end

