task.delay(5.5, function() if LoadingFrame.Parent then LoadingFrame:Destroy(); MainMenu.Visible = true end end)

task.spawn(function()
    while task.wait(0.2) do
        -- Main Logic Loop
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            -- HANYA jalankan jika _G.WS bernilai true
            if _G.WS == true then 
                LocalPlayer.Character.Humanoid.WalkSpeed = 100 
            end
            -- Jika _G.WS nil atau false, kita tidak melakukan apa-apa 
            -- sehingga kecepatan asli bawaan game kamu tetap terjaga.
        end
        
        -- Clean ESP if Disabled
        if not _G.ESP then
            for _, player in pairs(Players:GetPlayers()) do
                if player.Character then
                    if player.Character:FindFirstChild("Head") and player.Character.Head:FindFirstChild("InfoTag") then player.Character.Head.InfoTag:Destroy() end
                    if player.Character:FindFirstChild("Highlight") then player.Character.Highlight:Destroy() end
                end
            end
        end
    end
end)
